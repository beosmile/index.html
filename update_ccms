<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>C-CMS Wireframe – Draft Approval Flow</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --blue:         #1A5FD4;
  --blue-light:   #E6EFFF;
  --blue-mid:     #4A85E8;
  --green:        #0F7B5A;
  --green-light:  #D4F3E8;
  --green-mid:    #1BAF7E;
  --amber:        #C96E00;
  --amber-light:  #FEF3DC;
  --red:          #C0392B;
  --red-light:    #FDECEA;
  --teal:         #0D9488;
  --bg-event-main:#1E2D6B;
  --bg-event-sub: #3D1A6B;
  --border:       #D6DAE6;
  --border-light: #ECEEF4;
  --text-1:       #1A1D2B;
  --text-2:       #4A5070;
  --text-3:       #8890A8;
  --text-4:       #A0A8C0;
  --radius-sm:    5px;
  --radius-md:    8px;
  --radius-lg:    12px;
  --radius-xl:    16px;
  --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
  --shadow:     0 8px 40px rgba(0,0,0,0.13), 0 2px 8px rgba(0,0,0,0.07);
  --shadow-otp: 0 20px 64px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.1);
}

body {
  font-family: var(--font);
  background: #CDD0DC;
  min-height: 100vh;
  padding: 0;
}

/* ══════════════════════════════════════
   OUTER TAB BAR (top-level switcher)
══════════════════════════════════════ */
.outer-shell {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.outer-topbar {
  background: #12152A;
  padding: 0 28px;
  display: flex;
  align-items: stretch;
  gap: 0;
  position: sticky;
  top: 0;
  z-index: 200;
  box-shadow: 0 2px 12px rgba(0,0,0,0.25);
}

.outer-brand {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  letter-spacing: .05em;
  display: flex;
  align-items: center;
  padding-right: 24px;
  border-right: 1px solid rgba(255,255,255,0.1);
  margin-right: 8px;
  white-space: nowrap;
}
.outer-brand span { color: #1BAF7E; }

.outer-tab {
  font-size: 12.5px;
  font-weight: 500;
  color: rgba(255,255,255,0.5);
  padding: 14px 20px 12px;
  cursor: pointer;
  border-bottom: 3px solid transparent;
  transition: color .15s, border-color .15s;
  display: flex;
  align-items: center;
  gap: 7px;
  white-space: nowrap;
  user-select: none;
}
.outer-tab:hover { color: rgba(255,255,255,0.8); }
.outer-tab.active {
  color: #fff;
  border-bottom-color: #1BAF7E;
  font-weight: 600;
}
.outer-tab .tab-num {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.6);
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 10px;
}
.outer-tab.active .tab-num {
  background: rgba(27,175,126,0.25);
  color: #1BAF7E;
}

.outer-badge {
  font-size: 10px;
  font-weight: 700;
  background: #C0392B;
  color: #fff;
  padding: 2px 6px;
  border-radius: 8px;
  letter-spacing: .03em;
}

/* Pages */
.outer-page { display: none; }
.outer-page.active { display: block; }

/* Scroll area per page */
.page-scroll {
  padding: 28px 20px 48px;
  display: flex;
  justify-content: center;
}

/* ══════════════════════════════════════
   SHARED: BROWSER CHROME
══════════════════════════════════════ */
.browser-chrome {
  background: #1A1D2B;
  padding: 9px 18px;
  display: flex;
  align-items: center;
  gap: 7px;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}
.wdot { width: 11px; height: 11px; border-radius: 50%; }
.wdot.r { background: #FF5F57; }
.wdot.y { background: #FEBC2E; }
.wdot.g { background: #28C840; }
.w-url {
  margin-left: 8px;
  background: #2C3050;
  border-radius: 5px;
  padding: 4px 14px;
  font-size: 11.5px;
  color: #8890A8;
  flex: 1;
}

/* ══════════════════════════════════════
   SHARED: MODAL / DIALOG SHELL
══════════════════════════════════════ */
.cms-window {
  background: #fff;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow);
  overflow: hidden;
  position: relative;
}
.window-wrap {
  padding: 24px;
  position: relative;
}

/* ── Header ── */
.win-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 18px;
  border-bottom: 1px solid var(--border-light);
  background: #fff;
  flex-wrap: wrap;
  gap: 8px;
}
.win-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-1);
  display: flex;
  align-items: center;
  gap: 7px;
  flex-wrap: wrap;
}
.badge {
  font-size: 11px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 4px;
}
.badge-blue  { background: var(--blue-light); color: var(--blue); }
.badge-green { background: var(--green-light); color: #0A5E43; }

.win-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

/* ── Unsaved chip ── */
.unsaved-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 500;
  background: var(--amber-light);
  color: var(--amber);
  border: 1px solid #F7CB7A;
  border-radius: var(--radius-sm);
  padding: 4px 10px;
  white-space: nowrap;
}
.unsaved-chip::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--amber);
  animation: pulse-a 1.4s ease-in-out infinite;
}
@keyframes pulse-a {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:.35; transform:scale(.65); }
}

/* ── Buttons ── */
.btn {
  font-family: var(--font);
  font-weight: 600;
  border-radius: var(--radius-md);
  cursor: pointer;
  border: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: filter .15s, transform .1s;
  white-space: nowrap;
  font-size: 12.5px;
  padding: 7px 15px;
}
.btn:active { transform: scale(.97); }

.btn-update {
  background: linear-gradient(135deg, #0F7B5A 0%, #1BAF7E 100%);
  color: #fff;
  box-shadow: 0 2px 10px rgba(15,123,90,0.3);
}
.btn-update:hover { filter: brightness(1.07); }
.btn-update .lock {
  width: 13px; height: 13px;
  background: rgba(255,255,255,0.25);
  border-radius: 3px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.btn-add   { background: var(--blue); color: #fff; box-shadow: 0 2px 8px rgba(26,95,212,0.22); }
.btn-add:hover { filter: brightness(1.08); }

.btn-outline {
  background: #fff;
  color: var(--text-2);
  border: 1px solid var(--border);
}
.btn-outline:hover { background: #F2F4F8; }

.btn-danger {
  background: var(--red-light);
  color: var(--red);
  border: 1px solid #F5C6C2;
}
.btn-danger:hover { background: #fad6d3; }

.btn-primary {
  background: var(--blue);
  color: #fff;
  box-shadow: 0 2px 8px rgba(26,95,212,0.22);
}
.btn-primary:hover { filter: brightness(1.07); }

.btn-close {
  width: 30px; height: 30px;
  background: none;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-2);
  font-size: 16px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background .15s;
}
.btn-close:hover { background: #F2F4F8; }

/* ══════════════════════════════════════
   PAGE 1: PLAYLIST EDITOR
══════════════════════════════════════ */
#page-playlist .page-scroll { background: #CDD0DC; }

.p1-outer {
  width: 100%;
  max-width: 1060px;
}

.p1-browser {
  background: #1A1D2B;
  padding: 9px 18px;
  display: flex;
  align-items: center;
  gap: 7px;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

.p1-shell {
  background: #fff;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  overflow: hidden;
}

/* Modal body: timeline + sidebar */
.p1-body {
  display: flex;
  min-height: 360px;
}

/* Timeline */
.timeline {
  flex: 1;
  padding: 16px 18px;
  border-right: 1px solid var(--border-light);
  overflow-x: auto;
  min-width: 0;
}
.tl-col-heads {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
  padding-left: 52px;
}
.tl-col-head {
  flex: 1;
  font-size: 10.5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--text-3);
}
.tl-row {
  display: flex;
  align-items: stretch;
  gap: 6px;
  margin-bottom: 7px;
}
.tl-time {
  font-size: 10.5px;
  color: var(--text-3);
  width: 34px;
  padding-top: 10px;
  text-align: right;
  flex-shrink: 0;
}
.tl-num {
  font-size: 12px;
  font-weight: 500;
  color: var(--text-2);
  width: 18px;
  padding-top: 10px;
  flex-shrink: 0;
}
.tl-events { flex: 1; display: flex; gap: 8px; }
.ev-card {
  flex: 1;
  border-radius: var(--radius-md);
  padding: 9px 10px 26px;
  position: relative;
  min-width: 0;
}
.ev-main { background: var(--bg-event-main); }
.ev-sub  { background: var(--bg-event-sub); }
.ev-screen {
  font-size: 9.5px;
  color: rgba(255,255,255,0.5);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
  margin-bottom: 3px;
}
.ev-name {
  font-size: 11.5px;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 210px;
}
.ev-dur {
  position: absolute;
  bottom: 7px; left: 8px;
  font-size: 10px;
  color: rgba(255,255,255,0.8);
  background: rgba(0,0,0,0.3);
  border-radius: 3px;
  padding: 1px 6px;
}
.ev-thumb {
  position: absolute;
  right: 7px; top: 8px;
  width: 36px; height: 28px;
  border-radius: 3px;
  background: rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
}

/* Sidebar */
.p1-sidebar {
  width: 205px;
  flex-shrink: 0;
  padding: 14px;
  background: #FAFAFA;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.sb-hint {
  font-size: 11px;
  color: var(--text-2);
  line-height: 1.6;
  background: #EEF3FF;
  border-left: 3px solid var(--blue);
  padding: 7px 9px;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}
.sb-field-label {
  font-size: 11px;
  color: var(--text-3);
  font-weight: 500;
  margin-bottom: 4px;
}
.sb-select {
  font-family: var(--font);
  font-size: 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 5px 8px;
  width: 100%;
  background: #fff;
  color: var(--text-1);
}
.sb-checkbox {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  color: var(--text-1);
}
.preview-box {
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.preview-hdr {
  font-size: 11px;
  color: var(--text-2);
  font-weight: 500;
  padding: 5px 9px;
  border-bottom: 1px solid var(--border-light);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.preview-play {
  width: 20px; height: 20px;
  background: var(--blue);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
}
.preview-screen {
  background: #151A30;
  height: 76px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700;
  color: #4DFFD2;
  letter-spacing: .06em;
}
.preview-bot {
  background: #0D0F1A;
  height: 22px;
  display: flex; align-items: center; justify-content: center;
  font-size: 9.5px;
  color: rgba(255,255,255,0.45);
  letter-spacing: .05em;
}
.sb-actions { display: flex; flex-direction: column; gap: 6px; margin-top: auto; }
.sb-btn {
  font-family: var(--font);
  font-size: 12px; font-weight: 600;
  padding: 8px; border: none;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: filter .15s;
}
.sb-btn:hover { filter: brightness(1.07); }
.sb-save    { background: var(--blue); color: #fff; }
.sb-replace { background: #E67E00; color: #fff; }
.sb-delete  { background: var(--red); color: #fff; }

/* Footer p1 */
.p1-footer {
  padding: 8px 18px;
  border-top: 1px solid var(--border-light);
  background: #FAFBFD;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 11.5px;
  color: var(--text-3);
  flex-wrap: wrap;
}
.footer-tag {
  background: var(--blue); color: #fff;
  font-size: 11px; font-weight: 600;
  padding: 2px 9px; border-radius: 4px;
}
.p1-footer-status {
  margin-left: auto;
  display: flex; align-items: center; gap: 5px;
  color: var(--amber);
  font-weight: 500;
  font-size: 11px;
}
.p1-footer-status::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--amber);
}

/* ══════════════════════════════════════
   PAGE 2: SỬA SỰ KIỆN
══════════════════════════════════════ */
.p2-outer {
  width: 100%;
  max-width: 660px;
}

/* Inner tabs (Tổng quan / Định vị / Tiêu chí) */
.inner-tabs {
  display: flex;
  padding: 0 20px;
  border-bottom: 1px solid var(--border-light);
  background: #fff;
}
.inner-tab {
  font-size: 13px;
  font-weight: 500;
  padding: 10px 16px;
  color: var(--text-3);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color .15s, border-color .15s;
  user-select: none;
}
.inner-tab.active { color: var(--blue); border-bottom-color: var(--blue); font-weight: 600; }
.inner-tab:hover:not(.active) { color: var(--text-2); }
.inner-panel { display: none; }
.inner-panel.active { display: block; }

/* Form */
.form-body {
  padding: 20px 22px;
  display: flex;
  flex-direction: column;
  gap: 17px;
  max-height: 60vh;
  overflow-y: auto;
}
.form-row {
  display: grid;
  grid-template-columns: 135px 1fr;
  gap: 8px 14px;
  align-items: start;
}
.form-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-1);
  padding-top: 8px;
  line-height: 1.4;
}
.form-cw { display: flex; flex-direction: column; gap: 4px; }

input[type=text].fi,
input[type=number].fi,
select.fi {
  font-family: var(--font);
  font-size: 13px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 7px 11px;
  color: var(--text-1);
  background: #FAFBFD;
  outline: none;
  width: 100%;
  transition: border-color .15s, box-shadow .15s;
}
input[type=text].fi:focus,
input[type=number].fi:focus,
select.fi:focus {
  border-color: var(--blue-mid);
  box-shadow: 0 0 0 3px rgba(26,95,212,0.1);
  background: #fff;
}
.hint {
  font-size: 11.5px;
  color: var(--text-4);
  line-height: 1.5;
}
.tag-input {
  font-family: var(--font);
  font-size: 13px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 5px 10px;
  background: #FAFBFD;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 5px;
  min-height: 36px;
  cursor: text;
}
.tag-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: var(--blue-light);
  color: var(--blue);
  font-size: 12px; font-weight: 500;
  border-radius: 4px;
  padding: 2px 8px;
}
.playlist-row { display: flex; gap: 8px; align-items: stretch; }
.playlist-row input.fi { flex: 1; background: #F2F4F8; color: var(--text-2); }
.btn-change {
  font-family: var(--font);
  font-size: 12px; font-weight: 600;
  padding: 7px 13px;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  background: #fff;
  color: var(--text-2);
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background .15s;
}
.btn-change:hover { background: #F2F4F8; }
.btn-preview-tl {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: var(--font);
  font-size: 13px; font-weight: 600;
  padding: 8px 16px;
  border-radius: var(--radius-md);
  border: none;
  background: var(--teal);
  color: #fff;
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(13,148,136,0.22);
  transition: filter .15s;
}
.btn-preview-tl:hover { filter: brightness(1.07); }
.cb-row {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  color: var(--text-1);
  line-height: 1.5;
}
.cb-row input[type=checkbox] { width:15px;height:15px;margin-top:2px;cursor:pointer;flex-shrink:0; }
.divider-line { border: none; border-top: 1px solid var(--border-light); margin: 0 -22px; }

/* p2 footer */
.p2-footer {
  padding: 12px 18px;
  border-top: 1px solid var(--border-light);
  background: #F5F6FA;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.p2-footer-actions { display: flex; align-items: center; gap: 8px; margin-left: auto; flex-wrap: wrap; }

/* ══════════════════════════════════════
   SHARED OTP OVERLAY
══════════════════════════════════════ */
.otp-overlay {
  position: absolute;
  inset: 0;
  background: rgba(15,20,40,0.56);
  backdrop-filter: blur(3px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 100;
  border-radius: var(--radius-xl);
}
.otp-overlay.active { display: flex; }
.otp-card {
  background: #fff;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-otp);
  padding: 26px 30px;
  width: 336px;
  animation: pop-in .2s ease;
}
@keyframes pop-in {
  from { opacity:0; transform:translateY(14px) scale(.97); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}
.otp-icon-wrap {
  width: 50px; height: 50px;
  border-radius: 50%;
  background: var(--green-light);
  border: 2px solid rgba(15,123,90,0.16);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 13px;
}
.otp-icon-wrap svg { width: 24px; height: 24px; }
.otp-title {
  font-size: 15px; font-weight: 700;
  color: var(--text-1);
  text-align: center;
  margin-bottom: 5px;
}
.otp-desc {
  font-size: 12.5px;
  color: var(--text-2);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 13px;
}
.otp-desc strong { color: var(--text-1); }
.warn-banner {
  display: flex;
  align-items: flex-start;
  gap: 7px;
  font-size: 11.5px; font-weight: 500;
  background: var(--amber-light);
  color: var(--amber);
  border: 1px solid #F7CB7A;
  border-radius: var(--radius-md);
  padding: 8px 11px;
  margin-bottom: 16px;
  line-height: 1.5;
}
.warn-banner svg { flex-shrink: 0; margin-top: 1px; }
.otp-row {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-bottom: 9px;
}
.otp-digit {
  width: 42px; height: 50px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  font-size: 22px; font-weight: 700;
  text-align: center;
  color: var(--text-1);
  background: #FAFBFD;
  outline: none;
  font-family: var(--font);
  caret-color: var(--blue);
  transition: border-color .15s, box-shadow .15s;
}
.otp-digit:focus { border-color: var(--blue-mid); box-shadow: 0 0 0 3px rgba(26,95,212,0.12); background: #fff; }
.otp-digit.filled { border-color: var(--green-mid); background: var(--green-light); color: #0A5E43; }
