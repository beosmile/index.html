  cursor: pointer;
  transition: background .15s;
}
.otp-btn-cancel:hover { background: #F2F4F8; }
.otp-btn-confirm {
  flex: 2;
  font-family: var(--font);
  font-size: 13px; font-weight: 700;
  padding: 10px;
  border: none;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, #0F7B5A 0%, #1BAF7E 100%);
  color: #fff;
  cursor: pointer;
  box-shadow: 0 3px 10px rgba(15,123,90,0.28);
  transition: filter .15s, transform .1s;
}
.otp-btn-confirm:hover { filter: brightness(1.06); }
.otp-btn-confirm:active { transform: scale(.97); }
.otp-success { display: none; text-align: center; padding: 4px 0; animation: fade-in .3s ease; }
.otp-success.show { display: block; }
@keyframes fade-in { from { opacity:0; } to { opacity:1; } }
.success-icon {
