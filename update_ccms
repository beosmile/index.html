/* ═══════ APPROVE OTP ═══════ */
var cdTimers = {};

function openApproveOTP(scope, successMsg){
  var overlay = document.getElementById('approve-otp-'+scope);
  if(!overlay) return;
  overlay.style.display='flex';
  overlay._successMsg = successMsg;
  var digits = overlay.querySelectorAll('.approve-otp-digit');
  digits.forEach(function(d){d.value='';d.classList.remove('filled','oerr');});
  var cd = overlay.querySelector('.approve-cd');
  if(cd) cd.textContent='60';
  startApproveCD(scope, overlay);
  setTimeout(function(){ if(digits[0]) digits[0].focus(); }, 60);
}

function closeApproveOTP(scope){
  var overlay = document.getElementById('approve-otp-'+scope);
  if(overlay) overlay.style.display='none';
  clearInterval(cdTimers['a'+scope]);
}

function confirmApproveOTP(scope){
  var overlay = document.getElementById('approve-otp-'+scope);
  var digits = Array.from(overlay.querySelectorAll('.approve-otp-digit'));
  if(digits.some(function(d){return !d.value;})){
    digits.forEach(function(d){if(!d.value)d.classList.add('oerr');});
    return;
  }
  clearInterval(cdTimers['a'+scope]);
  var msg = overlay._successMsg || 'Draft đã được approve thành công.';
  var card = overlay.querySelector('.approve-otp-card');
  card.innerHTML = '<div style="text-align:center;padding:4px 0;">'
    +'<div style="width:52px;height:52px;border-radius:50%;background:#D4F3E8;border:2px solid rgba(15,123,90,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">'
    +'<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M7 12.5l3.5 3.5 6.5-7" stroke="#0F7B5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'
    +'<div style="font-size:15px;font-weight:700;color:#1A1D2B;margin-bottom:6px;">Approve thành công!</div>'
    +'<div style="font-size:12.5px;color:#4A5070;line-height:1.6;margin-bottom:18px;">'+msg+'</div>'
    +'<button onclick="closeApproveOTP(\''+scope+'\')" style="font-family:inherit;font-size:13px;font-weight:600;padding:9px 24px;border:none;border-radius:8px;background:#1BAF7E;color:#fff;cursor:pointer;width:100%;">Đóng</button>'
    +'</div>';
}

function startApproveCD(scope, overlay){
  var s=60;
  clearInterval(cdTimers['a'+scope]);
  cdTimers['a'+scope] = setInterval(function(){
    s--;
    var cd = overlay.querySelector('.approve-cd');
    if(cd) cd.textContent=s;
    if(s<=0) clearInterval(cdTimers['a'+scope]);
  },1000);
}

/* Approve OTP keyboard nav */
document.addEventListener('input', function(e){
  if(!e.target.classList.contains('approve-otp-digit')) return;
  var box = e.target.closest('.approve-otp-overlay');
  if(!box) return;
  var all = Array.from(box.querySelectorAll('.approve-otp-digit'));
  var idx = all.indexOf(e.target);
  e.target.value = e.target.value.replace(/\D/g,'');
  e.target.classList.toggle('filled',!!e.target.value);
  e.target.classList.remove('oerr');
  if(e.target.value && idx<all.length-1) all[idx+1].focus();
});
document.addEventListener('keydown', function(e){
  if(!e.target.classList.contains('approve-otp-digit')) return;
  var box = e.target.closest('.approve-otp-overlay');
  if(!box) return;
  var all = Array.from(box.querySelectorAll('.approve-otp-digit'));
  var idx = all.indexOf(e.target);
  if(e.key==='Backspace' && !e.target.value && idx>0){
    all[idx-1].focus(); all[idx-1].value=''; all[idx-1].classList.remove('filled');
  }
});

/* ═══════ USER-SIDE OTP (màn hình 1&2) ═══════ */
function openOTP(scope){
  document.getElementById('otp-'+scope).classList.add('active');
  document.getElementById('otp-'+scope+'-form').style.display='block';
  document.getElementById('otp-'+scope+'-success').classList.remove('show');
  resetOTP(scope); startCD(scope);
  setTimeout(function(){
    var f=document.querySelector('[data-scope="'+scope+'"].otp-digit');
    if(f) f.focus();
  },60);
}
function closeOTP(scope){
  document.getElementById('otp-'+scope).classList.remove('active');
  clearInterval(cdTimers[scope]);
}
function confirmOTP(scope){
  var digits=Array.from(document.querySelectorAll('[data-scope="'+scope+'"].otp-digit'));
  if(digits.some(function(d){return !d.value;})){
    digits.forEach(function(d){if(!d.value)d.classList.add('oerr');}); return;
  }
  document.getElementById('otp-'+scope+'-form').style.display='none';
  document.getElementById('otp-'+scope+'-success').classList.add('show');
  clearInterval(cdTimers[scope]);
  if(scope==='p1'){
    var chip=document.getElementById('p1-unsaved');
    if(chip) chip.style.opacity='.3';
    var st=document.getElementById('p1-footer-status');
    if(st){st.textContent='✓ Đã đẩy lịch phát thành công';st.style.color='var(--green)';}
  } else {
    var c=document.getElementById('p2-unsaved');
    if(c) c.style.opacity='.3';
  }
}
function resetOTP(scope){
  document.querySelectorAll('[data-scope="'+scope+'"].otp-digit').forEach(function(d){
    d.value='';d.classList.remove('filled','oerr');
  });
}
function startCD(scope){
  var s=60, link=document.getElementById(scope+'-resend-link'), cdEl=document.getElementById(scope+'-cd');
  if(cdEl) cdEl.textContent=s;
  if(link){link.style.pointerEvents='none';link.style.opacity='.5';}
  clearInterval(cdTimers[scope]);
  cdTimers[scope]=setInterval(function(){
    s--;
    var el=document.getElementById(scope+'-cd');
    if(el) el.textContent=s;
    if(s<=0){
      clearInterval(cdTimers[scope]);
      if(link){link.style.pointerEvents='auto';link.style.opacity='1';link.textContent='Gửi lại mã OTP';}
    }
  },1000);
}
document.addEventListener('input',function(e){
  if(!e.target.classList.contains('otp-digit')) return;
  var scope=e.target.dataset.scope;
  var all=Array.from(document.querySelectorAll('[data-scope="'+scope+'"].otp-digit'));
  var idx=all.indexOf(e.target);
  e.target.value=e.target.value.replace(/\D/g,'');
  e.target.classList.toggle('filled',!!e.target.value);
  e.target.classList.remove('oerr');
  if(e.target.value && idx<all.length-1) all[idx+1].focus();
});
document.addEventListener('keydown',function(e){
  if(!e.target.classList.contains('otp-digit')) return;
  var scope=e.target.dataset.scope;
  var all=Array.from(document.querySelectorAll('[data-scope="'+scope+'"].otp-digit'));
  var idx=all.indexOf(e.target);
  if(e.key==='Backspace' && !e.target.value && idx>0){
    all[idx-1].focus();all[idx-1].value='';all[idx-1].classList.remove('filled');
  }
});
